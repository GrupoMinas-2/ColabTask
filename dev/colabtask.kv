
# REGRAS ===============================================
#
# padrão para o fundo da tela -------
<BGwhite@BoxLayout>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: ( 1, 1, 1, 1 )
        Rectangle: 
            pos: self.pos
            size: self.size

# padrão para input -------
<BoxInput@BoxLayout>:
    size_hint_y: None
    height: dp(40)
    padding: dp(6) 
    spacing: dp(8)

    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        RoundedRectangle:
            pos: self.x, self.y
            size: self.size
            radius: [10]

#padrão dos botões de entrada ------
<EnterButton@Button>:
    
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0  
    color: 1, 1, 1, 1  

    canvas.before:
        Color:
            rgba: ( 0, 0.5, 0.9, 1 )
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

#padrão textinputs de um modal ------
<TextInputModal@TextInput>:
    height: dp(10)
    padding: [0, 4]
    background_normal: ''
    background_active: ''
    background_color: (0, 0, 0, 0)

#padrão button behavior ------
<ItenBehavior@ButtonBehavior+BoxLayout>:
    canvas.before:
        Color: 
            rgba: (1, 1, 1, 1) if self.state == 'normal' else (0.7, 0.7, 0.7, 1)
        Rectangle: 
            size: root.size 
            pos: root.pos 

#
# PAGINAS ===============================================
#
# Page manager______________________
<ControllerTelas>:
    LoginPage:
        name: ('loginpage')

    RegisterPage:
        name: ('registerpage')

    HomePage:
        name: ('homepage')

    TasksPage:
        name: ('taskspage')
        
#
# Screen login ____________________________________
<LoginPage>:
    
    BGwhite:
        id: loginLayout

        padding: dp(50)
        spacing: dp(30)
        
        Image: 
            size_hint_y: 0.5
            source:'images/listIcon copy.png'

        # mail user________
        BoxInput:

            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source:'images/listIcon copy.png'
            
            TextInput:
                id: inputMail
                hint_text: "E-mail"
                multiline: False

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.9
                padding: [10, 5]
        
        # password user________
        BoxInput:
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source:'images/listIcon copy.png'  

            TextInput:
                id: inpuPassword
                hint_text: "Senha"
                multiline: False

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.9
                padding: [10, 5]
        
        BoxLayout:
            size_hint_y: 0.2
            spacing: dp(5)
            EnterButton:
                id: btnAccess
                size_hint_y: None
                size_hint_x: 0.4
                height: dp(40)
                text: 'Entrar'
                on_release: app.root.current= 'homepage'

            EnterButton:
                id: btnReirect
                size_hint_y: None
                size_hint_x: 0.2
                height: dp(40)
                text: 'cadastrar'
                on_release: app.root.current= 'registerpage'



# Screen cadastro ____________________________________
<RegisterPage>:
    
    BGwhite: 
        id: registerLayout

        padding: dp(50)
        spacing: dp(30)

        Image: 
            source:'images/listIcon copy.png'


        # mail user________
        BoxInput: 
            
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source:'images/listIcon copy.png'

            TextInput: 
                id: inputMail
                hint_text: "E-mail"
                multiline: False

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.9
                padding: [10, 5] 


        # name user_______
        BoxInput:
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source: 'images/listIcon copy.png'
            
            TextInput: 
                id: inputNameUser
                multiline: False
                hint_text: "Nome"

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.8
                padding: [10, 5]

        
        # password user______
        BoxInput:
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source: 'images/listIcon copy.png'

            TextInput:
                id: inputPassword
                password: True
                multiline: False
                hint_text: "Senha"

                background_normal: ''
                background_active: ''
                background_color: 0, 0, 0, 0

                size_hint_x: 0.8
                padding: [10, 5]
                

        EnterButton: 
            
            size_hint_y: None
            text: "Criar conta"
            height: dp(40)
            on_release: app.root.current ='homepage'



# Screen núcleos familiares ____________________________________
<HomePage>: 
    padding: [0]
    BGwhite:
        id: homeLayout

        #FloatLayout:
            # size_hint_y: 0.09
            # orientation: 'vertical'
            # ActionBar:
            #    pos_hint: {'top': 1}
            #    ActionView:
            #       ActionPrevious:
            #           on_release: app.root.current= 'loginpage'

        ScrollView:          
            do_scroll_x: False

            BoxLayout:
                id: containerNucleos
                orientation: 'vertical'
                padding: 10
                size_hint_y: None
                height: self.minimum_height 

        BoxLayout:
            size_hint_y: 0.1
            padding: [60, 4]   

            Button:
                text: "novo Nucleo" 
                on_release: root.insertModal()


# Screen tarefas ____________________________________
<TasksPage>:
    BGwhite:
        id: taskslayout
        
        Label:
            text: 'minhas tarefas'
            font_size: 40
            color: (0,0,0,1)

        ScrollView:
            do_scroll_x: False 

            BoxLayout:
                id: containerTarefa
                orientation: 'vertical'
                padding: 10
                size_hint_y: None
                height: self.minimum_height
       
        BoxLayout:
            size_hint_y: 0.1
            padding: [20, 5]
            
            Button:
                text: 'criar tarefa'
                on_release: root.insertModal()
                


#
# ELEMENTOS ===============================================
#
# Modal de criação de núcleos
<ModalNucleo>:
# Núcleo
<Nucleo>:
    id: nucleo
    size_hint_y: None
    height: dp(60)
    ItenBehavior:
        padding: 0
        on_release: app.root.current= 'taskspage'

        canvas.before:
            Color:
                rgba: (0.5, 0.5, 0.5, 1)
            Line:
                rectangle: (app.root.get_screen("homepage").ids.containerNucleos.x, self.y, app.root.get_screen("homepage").ids.containerNucleos.width, self.height)
                width: 1

        Image:
            size_hint_x: 0.5
            id: taskImage
            source: 'images/ui_user_profile_avatar_person_icon_208734.png'

        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 2

            Label:
                id: nucleoTitle
                text: "nome núcleo"
                font_size: 20
                halign: 'left'
                text_size: self.size
                color: (0, 0, 0, 1)

            Label:
                id: taskDescription
                text: "descrição"
                halign: 'left'
                valign: 'top'
                text_size: self.size
                color: (0.4, 0.4, 0.4, 1)




    size_hint: 0.9, 0.6 # o widget ocupa porcentagem da tela
    auto_dismiss: False # tenho que chamar o dismiss() 
    
    BGwhite:
        id: modalNucleo
        padding: [20, 10]
        spacing: 10

        Label:
            text: "Novo núcleo" 
            font_size: 25
            halign: "left"
            text_size: self.size
            size_hint_y: None
            height: dp(30)
            color: (0, 0, 0, 1)


        # campo de nome ------------------
        BoxLayout:
            size_hint_y: None
            height: 60
            #padding: [0, 10]

            Image:
                source: 'images/ui_user_profile_avatar_person_icon_208734.png'
                allow_stretch: True
                size_hint_x: 0.7
                size_hint_y: 1

            TextInputModal:
                id: inputTitle
                hint_text: "titulo"
                multiline: False    
                size_hint_y: None
                pos_hint_y: 1
                size_hint_x: 2
                height: dp(30)
                canvas.after:
                    Color:
                        rgba: 0.6, 0.6, 0.6, 1 
                    Line:
                        points: [self.x, self.y , self.right, self.y]  
                        width: 1.2                


        # Divisoria entre os campos ---------------
        BoxLayout: 
            height: 5
            size_hint_y: 0.2
            canvas.before:
                Color: 
                    rgba: (0.5, 0.5, 0.5, 1)
                Line: 
                    points: (self.x , self.y, self.right, self.y)
                    width: 1.2


        # Campo de descrição --------------   
        BoxLayout: 
            orientation: 'vertical'
            size_hint_y: 2
            spacing: dp(5)
            padding: [0, 10]
            Label: 
                text: 'Descrição'
                font_size: 25
                color: (0, 0, 0, 1)
                halign: 'left'
                text_size: self.size
                size_hint_y: 0.5
                height: dp(20)

            TextInputModal: 
                id: inputDescription
                hint_text: "Descrição"
                multiline: True
                size_hint_y: 2
                height: dp(40)
                padding: dp(5)
                color: (1, 1, 1, 1)

                canvas.before: 
                    Color:  
                        rgba: (0.5, 0.5, 0.5, 1)
                    Line: 
                        rounded_rectangle:(self.x, self.y, self.width, self.height, 5)
                        width: 1.02

                
        # bottões para criar e cancelar -------------
        BoxLayout:
            spacing: dp(5)
            size_hint_y: 0.5
            EnterButton:
                size_hint_x: 2
                text: 'Criar'
                on_release: app.root.get_screen("homepage").insertNucleo() , root.dismiss()
            
            Button:
                text: 'Cancelar'
                size_hint_x: 1
                on_release: root.dismiss()

                background_normal: ''
                background_down: ''
                background_color: 0, 0, 0, 0  
                color: 1, 1, 1, 1
                canvas.before:
                    Color: 
                        rgba: 0.6, 0.6, 0.6, 1
                    RoundedRectangle: 
                        pos: self.pos
                        size: self.size
                        radius: [10]
                    

# Modal de criação de tarefas
<ModalTask>:
    size_hint: 0.9 , 0.6
    auto_dismiss: True

    BGwhite:
        id: modalTask
        padding: [10, 30]
        
        Label:
            text: 'modal ativado'
