# REGRAS --------------------------

# padrão para o fundo da tela -------
<BGwhite@BoxLayout>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: ( 1, 1, 1, 1 )
        Rectangle: 
            pos: self.pos
            size: self.size

# padrão para input -------
<BoxInput@BoxLayout>:
    size_hint_y: None
    height: dp(40)
    padding: dp(6) 
    spacing: dp(8)

    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        RoundedRectangle:
            pos: self.x, self.y
            size: self.size
            radius: [10]

#padrão dos botões de entrada ------
<EnterButton@Button>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0  
    color: 1, 1, 1, 1  

    canvas.before:
        Color:
            rgba: ( 0, 0.5, 0.9, 1 )
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

#

# PAGINAS ----------------------
# Page manager______________________
<ControllerTelas>:
    LoginPage:
        name: ('loginpage')

    RegisterPage:
        name: ('registerpage')

    HomePage:
        name: ('homepage')
        


# Screen login _________________________
<LoginPage>:
    
    BGwhite:
        id: loginLayout

        padding: dp(50)
        spacing: dp(30)
        
        Image: 
            size_hint_y: 0.5
            source:'images/listIcon copy.png'

        # mail user________
        BoxInput:

            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source:'images/listIcon copy.png'
            
            TextInput:
                id: inputMail
                hint_text: "E-mail"
                multiline: False

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.9
                padding: [10, 5]
        
        # password user________
        BoxInput:
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source:'images/listIcon copy.png'  

            TextInput:
                id: inpuPassword
                hint_text: "Senha"
                multiline: False

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.9
                padding: [10, 5]
        
        BoxLayout:
            size_hint_y: 0.2
            spacing: dp(5)
            EnterButton:
                id: btnAccess
                size_hint_y: None
                size_hint_x: 0.4
                height: dp(40)
                text: 'Entrar'
                on_release: app.root.current= 'homepage'

            EnterButton:
                id: btnReirect
                size_hint_y: None
                size_hint_x: 0.2
                height: dp(40)
                text: 'cadastrar'
                on_release: app.root.current= 'registerpage'



# Screen cadastro ____________________________________
<RegisterPage>:
    
    BGwhite: 
        id: registerLayout

        padding: dp(50)
        spacing: dp(30)

        Image: 
            source:'images/listIcon copy.png'


        # mail user________
        BoxInput: 
            
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source:'images/listIcon copy.png'

            TextInput: 
                id: inputMail
                hint_text: "E-mail"
                multiline: False

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.9
                padding: [10, 5] 


        # name user_______
        BoxInput:
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source: 'images/listIcon copy.png'
            
            TextInput: 
                id: inputNameUser
                multiline: False
                hint_text: "Nome"

                background_normal: ''
                background_active: ''
                background_color: (0, 0, 0, 0)

                size_hint_x: 0.8
                padding: [10, 5]

        
        # password user______
        BoxInput:
            Image:
                size_hint_x: 0.2
                allow_stretch: True
                source: 'images/listIcon copy.png'

            TextInput:
                id: inputPassword
                password: True
                multiline: False
                hint_text: "Senha"

                background_normal: ''
                background_active: ''
                background_color: 0, 0, 0, 0

                size_hint_x: 0.8
                padding: [10, 5]
                

        EnterButton: 
            
            size_hint_y: None
            text: "Criar conta"
            height: dp(40)
            on_release: app.root.current ='homepage'



# Screen núcleos familiares ____________________________________
<HomePage>: 
    BGwhite:
        id: homeLayout

        FloatLayout:
            size_hint_y: 0.09
            orientation: 'vertical'

            ActionBar:
                pos_hint: {'top': 1}
                ActionView:
                    ActionPrevious:
                        on_release: app.root.current= 'loginpage'

        ScrollView:
            do_scroll_x: False

            BoxLayout:
                id: containerNucleos
                orientation: 'vertical'

                padding: 10
        
        BoxLayout:
            size_hint_y: 0.1
            padding: 60, 4   

            Button:
                text: "adicionar" 
                on_release: root.insertModal()

#
       
# ELEMENTOS --------------------

# Núcleo
<Nucleo>:
    id: nucleo
    size_hint_y: None
    height: dp(200)
    BoxLayout:
        Image:
            id: taskImage
            source: 'images/listIcon copy.png'

        BoxLayout:
            orientation: 'vertical'
            Label:
                id: nucleoTitle
                text: "tarefa"
                font_size: 35

            Label:
                id: taskDescription
                text: "09/09/2009"

# Modal de criação de núcleos
<ModalNucleo>:
    size_hint: 0.9, 0.6 # o widget ocupa porcentagem da tela
    auto_dismiss: True # tenho que chamar o dismiss() 
    
    BGwhite:
        id: modalNucleo
        padding: [30, 40]
        spacing: 10
        

        Label:
            text: "Novo núcleo" 
            font_size: 20
            text_size: self.size 
            halign: "left"
            size_hint_y: None
            height: dp(30)
            color: (0, 0, 0, 1)

        BoxLayout:
            size_hint_y: None
            height: 60
            Image:
                source: 'images/ui_user_profile_avatar_person_icon_208734.png'
                allow_stretch: True
                size_hint_x: 0.7
                size_hint_y: 1

            TextInput:
                id: inputTitle
                hint_text: "titulo"
                multiline: False    
                size_hint_y: None
                size_hint_x: 2
                height: dp(40)
                
        Label:
            text: 'Descrição'
            color: (0, 0, 0, 1)
            font_size: 20
            text_size: self.size
            halign: 'left'
            size_hint_y: None
            height: dp(20)

        TextInput:
            id: inputDescription
            hint_text: "Descrição"
            multiline: True
            size_hint_y: 2
            height: dp(40)
        
        BoxLayout:
            spacing: dp(5)
            size_hint_y: 1
            EnterButton:
                size_hint_x: 2
                text: 'Criar'
                
                on_release: root.dismiss()
            
            Button:
                text: 'Cancelar'
                size_hint_x: 1
                on_release: root.dismiss()

                background_normal: ''
                background_down: ''
                background_color: 0, 0, 0, 0  
                color: 1, 1, 1, 1
                canvas.before:
                    Color: 
                        rgba: 0.6, 0.6, 0.6, 1
                    RoundedRectangle: 
                        pos: self.pos
                        size: self.size
                        radius: [10]
                    


