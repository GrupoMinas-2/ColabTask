# page manager______________________
<ControlerTelas>:
    LoginPage:


<LoginPage>:
    BoxLayout: 
        id: login
        orientation: 'vertical'
        padding: 50
        spacing: 30

        Image: 
            source:'images/listIcon copy.png'

        # name user______________________
        BoxLayout: 
            id: nameUser
            size_hint_y: None
            height: 40
            
            Image:
                size_hint_x: 0.2
                source:'images/listIcon copy.png'
            
            TextInput: 
                allow_stretch: True
                id: inputName

        # id user______________________
        BoxLayout: 
            id: identifierUser
            size_hint_y: None
            height: 40

            Image:
                size_hint_x: 0.2
                source:'images/listIcon copy.png'
            
            TextInput: 
                id: inputUser
        
        
        # pasword user______________________
        BoxLayout: 
            id: passwordUser
            size_hint_y: None
            height: 40

            Image:
                size_hint_x: 0.2
                source: 'images/listIcon copy.png'
            
            TextInput: 
                password: True
                id: passwordInput

        Button: 
            size_hint_y: None
            text: "iniciando"
            height: 50

    